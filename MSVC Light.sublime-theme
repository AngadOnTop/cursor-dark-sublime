{
  "extends": "Adaptive.sublime-theme",
  "variables": {
    "msvc_bg": "#FFFFFF",
    "msvc_bg_alt": "#F3F3F3",
    "msvc_bg_hover": "#E8F2FF",
    "msvc_bg_selected": "#DDEEFF",
    "msvc_border": "#D6D6D6",
    "msvc_text": "#111111",
    "msvc_text_dim": "#2B2B2B",
    "msvc_text_faint": "#3F3F3F",
    "msvc_accent": "#007ACC",
    "msvc_accent_alt": "#2B7A7F",
    "msvc_icon": "#111111",
    "msvc_icon_hover": "#000000",
    "msvc_icon_selected": "#005A9E",
    "mizu_folder": "#ffa040"
  },
  "rules": [
    {
      "class": "sidebar_container",
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 1
    },
    {
      "class": "sidebar_tree",
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 1,
      "indent": 12,
      "indent_offset": 8
    },
    {
      "class": "tree_row",
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 0
    },
    {
      "class": "tree_row",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(msvc_bg_hover)",
      "layer0.opacity": 1
    },
    {
      "class": "tree_row",
      "attributes": [
        "selected"
      ],
      "layer0.tint": "var(msvc_bg_selected)",
      "layer0.opacity": 1
    },
    {
      "class": "tree_label",
      "fg": "var(msvc_text_dim)"
    },
    {
      "class": "tree_label",
      "parents": [
        {
          "class": "tree_row",
          "attributes": [
            "hover"
          ]
        }
      ],
      "fg": "var(msvc_text)"
    },
    {
      "class": "tree_label",
      "parents": [
        {
          "class": "tree_row",
          "attributes": [
            "selected"
          ]
        }
      ],
      "fg": "var(msvc_text)"
    },
    {
      "class": "tabset_control",
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 1
    },
    {
      "class": "tab_control",
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 1,
      "content_margin": [
        12,
        7,
        12,
        7
      ]
    },
    {
      "class": "tab_control",
      "attributes": [
        "selected"
      ],
      "layer0.tint": "var(msvc_bg)",
      "layer0.opacity": 1
    },
    {
      "class": "tab_control",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(msvc_bg_hover)",
      "layer0.opacity": 1
    },
    {
      "class": "tab_label",
      "fg": "var(msvc_text_faint)"
    },
    {
      "class": "tab_label",
      "parents": [
        {
          "class": "tab_control",
          "attributes": [
            "selected"
          ]
        }
      ],
      "fg": "var(msvc_text)"
    },
    {
      "class": "tab_label",
      "parents": [
        {
          "class": "tab_control",
          "attributes": [
            "hover"
          ]
        }
      ],
      "fg": "var(msvc_text)"
    },
    {
      "class": "sheet_contents",
      "layer0.tint": "var(msvc_bg)",
      "layer0.opacity": 1
    },
    {
      "class": "status_bar",
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 1
    },
    {
      "class": "status_label",
      "fg": "var(msvc_text_dim)"
    },
    {
      "class": "panel_control",
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 1
    },
    {
      "class": "quick_panel",
      "layer0.tint": "var(msvc_bg)",
      "layer0.opacity": 1
    },
    {
      "class": "quick_panel_row",
      "layer0.tint": "var(msvc_bg)",
      "layer0.opacity": 0
    },
    {
      "class": "quick_panel_row",
      "attributes": [
        "selected"
      ],
      "layer0.tint": "var(msvc_bg_selected)",
      "layer0.opacity": 1
    },
    {
      "class": "mini_quick_panel_row",
      "attributes": [
        "selected"
      ],
      "layer0.tint": "var(msvc_bg_selected)",
      "layer0.opacity": 1
    },
    {
      "class": "overlay_control",
      "layer0.tint": "var(msvc_bg)",
      "layer0.opacity": 1
    },
    {
      "class": "popup_control",
      "layer0.tint": "var(msvc_bg)",
      "layer0.opacity": 1
    },
    {
      "class": "auto_complete_popup",
      "layer0.tint": "var(msvc_bg)",
      "layer0.opacity": 1
    },
    {
      "class": "button_control",
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 1
    },
    {
      "class": "button_control",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(msvc_bg_hover)",
      "layer0.opacity": 1
    },
    {
      "class": "icon_button_control",
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 0
    },
    {
      "class": "icon_button_control",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(msvc_bg_hover)",
      "layer0.opacity": 1
    },
    {
      "class": "label_control",
      "fg": "var(msvc_text)"
    },
    {
      "class": "text_line_control",
      "layer0.tint": "var(msvc_bg)",
      "layer0.opacity": 1,
      "fg": "var(msvc_text)"
    },
    {
      "class": "scroll_bar_control",
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 0
    },
    {
      "class": "scroll_puck_control",
      "layer0.tint": "var(msvc_text)",
      "layer0.opacity": 0.18
    },
    {
      "class": "scroll_puck_control",
      "attributes": [
        "hover"
      ],
      "layer0.opacity": 0.32
    },
    {
      "class": "icon_button_control",
      "content_margin": [
        6,
        6
      ],
      "layer0.tint": "var(msvc_bg_alt)",
      "layer0.opacity": 0,
      "tint_modifier": [
        0,
        0,
        0,
        0.82
      ]
    },
    {
      "class": "icon_button_control",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(msvc_bg_hover)",
      "layer0.opacity": 1,
      "tint_modifier": [
        0,
        0,
        0,
        1
      ]
    },
    {
      "class": "disclosure_button_control",
      "layer0.tint": "var(msvc_icon)",
      "layer0.opacity": 1
    },
    {
      "class": "disclosure_button_control",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(msvc_icon_selected)",
      "layer0.opacity": 1
    },
    {
      "class": "close_button",
      "tint_modifier": [
        0,
        0,
        0,
        0.72
      ]
    },
    {
      "class": "close_button",
      "attributes": [
        "hover"
      ],
      "tint_modifier": [
        0,
        0,
        0,
        1
      ]
    },
    {
      "class": "tab_close_button",
      "tint_modifier": [
        0,
        0,
        0,
        0.72
      ]
    },
    {
      "class": "tab_close_button",
      "attributes": [
        "hover"
      ],
      "tint_modifier": [
        0,
        0,
        0,
        1
      ]
    },
    {
      "class": "label_control",
      "fg": "var(msvc_text)"
    },
    {
      "class": "quick_panel_label",
      "fg": "var(msvc_text)"
    },
    {
      "class": "quick_panel_path_label",
      "fg": "var(msvc_text_dim)"
    },
    {
      "class": "sidebar_heading",
      "fg": "var(msvc_text)"
    },
    {
      "class": "sidebar_label",
      "fg": "var(msvc_text_dim)"
    },
    {
      "class": "sidebar_label",
      "parents": [
        {
          "class": "tree_row",
          "attributes": [
            "hover"
          ]
        }
      ],
      "fg": "var(msvc_text)"
    },
    {
      "class": "sidebar_label",
      "parents": [
        {
          "class": "tree_row",
          "attributes": [
            "selected"
          ]
        }
      ],
      "fg": "var(msvc_text)"
    },
    {
      "class": "icon_folder",
      "content_margin": [
        8,
        8
      ],
      "layer0.opacity": 1,
      "layer0.tint": "var(mizu_folder)"
    },
    {
      "class": "icon_folder_loading",
      "content_margin": [
        8,
        8
      ],
      "layer0.opacity": 1,
      "layer0.tint": "var(mizu_folder)"
    },
    {
      "class": "icon_folder_dup",
      "content_margin": [
        8,
        8
      ],
      "layer0.opacity": 0.85,
      "layer0.tint": "var(mizu_folder)"
    },
    {
      "class": "vcs_status_badge",
      "content_margin": [
        7,
        7
      ],
      "tint_modifier": [
        0,
        128,
        0,
        1
      ]
    },
    {
      "class": "disclosure_button_control",
      "content_margin": [
        8,
        8
      ],
      "layer0.tint": "var(msvc_icon)",
      "layer0.opacity": 1
    },
    {
      "class": "sidebar_button_control",
      "content_margin": [
        10,
        10
      ],
      "layer0.tint": "var(msvc_icon)",
      "layer0.opacity": 1
    },
    {
      "class": "panel_button_control",
      "content_margin": [
        10,
        10
      ],
      "layer0.tint": "var(msvc_icon)",
      "layer0.opacity": 1
    },
    {
      "class": "status_button",
      "layer0.tint": "var(msvc_icon)",
      "layer0.opacity": 1
    }
  ]
}
