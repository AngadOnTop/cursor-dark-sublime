{
  "extends": "Adaptive.sublime-theme",
  "variables": {
    "cursor_bg": "#181818",
    "cursor_bg_dark": "#141414",
    "cursor_bg_light": "#242424",
    "cursor_hover": "#262626",
    "cursor_border": "#2A2A2A",
    "cursor_text": "#E4E4E4",
    "cursor_text_dim": "#C8C8C8",
    "cursor_text_faint": "#B0B0B0",
    "cursor_accent": "#81A1C1",
    "cursor_accent_alt": "#88C0D0",
    "cursor_icon": "#F0F0F0",
    "cursor_icon_hover": "#FFFFFF",
    "cursor_icon_selected": "#88C0D0",
    "cursor_status_bg": "#101010",
    "cursor_status_button": "#101010",
    "cursor_status_button_hover": "#242424",
    "cursor_status_text": "#FFFFFF",
    "mizu_folder": "#ffa040"
  },
  "rules": [
    {
      "class": "sidebar_container",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 1
    },
    {
      "class": "sidebar_tree",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 1,
      "indent": 12,
      "indent_offset": 8
    },
    {
      "class": "tree_row",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 0
    },
    {
      "class": "tree_row",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(cursor_hover)",
      "layer0.opacity": 1
    },
    {
      "class": "tree_row",
      "attributes": [
        "selected"
      ],
      "layer0.tint": "var(cursor_hover)",
      "layer0.opacity": 1
    },
    {
      "class": "tree_label",
      "fg": "var(cursor_text_dim)"
    },
    {
      "class": "tree_label",
      "parents": [
        {
          "class": "tree_row",
          "attributes": [
            "hover"
          ]
        }
      ],
      "fg": "var(cursor_text)"
    },
    {
      "class": "tree_label",
      "parents": [
        {
          "class": "tree_row",
          "attributes": [
            "selected"
          ]
        }
      ],
      "fg": "var(cursor_text)"
    },
    {
      "class": "tabset_control",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 1
    },
    {
      "class": "tab_control",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 1,
      "content_margin": [
        12,
        7,
        12,
        7
      ]
    },
    {
      "class": "tab_control",
      "attributes": [
        "selected"
      ],
      "layer0.tint": "var(cursor_bg)",
      "layer0.opacity": 1
    },
    {
      "class": "tab_control",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(cursor_bg_light)",
      "layer0.opacity": 1
    },
    {
      "class": "tab_label",
      "fg": "var(cursor_text_faint)"
    },
    {
      "class": "tab_label",
      "parents": [
        {
          "class": "tab_control",
          "attributes": [
            "selected"
          ]
        }
      ],
      "fg": "var(cursor_text)"
    },
    {
      "class": "tab_label",
      "parents": [
        {
          "class": "tab_control",
          "attributes": [
            "hover"
          ]
        }
      ],
      "fg": "var(cursor_text)"
    },
    {
      "class": "sheet_contents",
      "layer0.tint": "var(cursor_bg)",
      "layer0.opacity": 1
    },
    {
      "class": "status_bar",
      "layer0.tint": "var(cursor_status_bg)",
      "layer0.opacity": 1
    },
    {
      "class": "status_label",
      "fg": "var(cursor_status_text)"
    },
    {
      "class": "panel_control",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 1
    },
    {
      "class": "quick_panel",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 1
    },
    {
      "class": "quick_panel_row",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 0
    },
    {
      "class": "quick_panel_row",
      "attributes": [
        "selected"
      ],
      "layer0.tint": "var(cursor_hover)",
      "layer0.opacity": 1
    },
    {
      "class": "mini_quick_panel_row",
      "attributes": [
        "selected"
      ],
      "layer0.tint": "var(cursor_hover)",
      "layer0.opacity": 1
    },
    {
      "class": "overlay_control",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 1
    },
    {
      "class": "popup_control",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 1
    },
    {
      "class": "auto_complete_popup",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 1
    },
    {
      "class": "button_control",
      "layer0.tint": "var(cursor_bg_light)",
      "layer0.opacity": 1
    },
    {
      "class": "button_control",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(cursor_hover)",
      "layer0.opacity": 1
    },
    {
      "class": "icon_button_control",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 0
    },
    {
      "class": "icon_button_control",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(cursor_hover)",
      "layer0.opacity": 1
    },
    {
      "class": "label_control",
      "fg": "var(cursor_text)"
    },
    {
      "class": "text_line_control",
      "layer0.tint": "var(cursor_bg)",
      "layer0.opacity": 1,
      "fg": "var(cursor_text)"
    },
    {
      "class": "scroll_bar_control",
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 0
    },
    {
      "class": "scroll_puck_control",
      "layer0.tint": "var(cursor_text)",
      "layer0.opacity": 0.12
    },
    {
      "class": "scroll_puck_control",
      "attributes": [
        "hover"
      ],
      "layer0.opacity": 0.22
    },
    {
      "class": "icon_button_control",
      "content_margin": [
        6,
        6
      ],
      "layer0.tint": "var(cursor_bg_dark)",
      "layer0.opacity": 0,
      "tint_modifier": [
        255,
        255,
        255,
        0.82
      ]
    },
    {
      "class": "icon_button_control",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(cursor_hover)",
      "layer0.opacity": 1,
      "tint_modifier": [
        255,
        255,
        255,
        1
      ]
    },
    {
      "class": "disclosure_button_control",
      "layer0.tint": "var(cursor_icon)",
      "layer0.opacity": 1
    },
    {
      "class": "disclosure_button_control",
      "attributes": [
        "hover"
      ],
      "layer0.tint": "var(cursor_icon_selected)",
      "layer0.opacity": 1
    },
    {
      "class": "close_button",
      "tint_modifier": [
        255,
        255,
        255,
        0.72
      ]
    },
    {
      "class": "close_button",
      "attributes": [
        "hover"
      ],
      "tint_modifier": [
        255,
        255,
        255,
        1
      ]
    },
    {
      "class": "tab_close_button",
      "tint_modifier": [
        255,
        255,
        255,
        0.72
      ]
    },
    {
      "class": "tab_close_button",
      "attributes": [
        "hover"
      ],
      "tint_modifier": [
        255,
        255,
        255,
        1
      ]
    },
    {
      "class": "label_control",
      "fg": "var(cursor_text)"
    },
    {
      "class": "quick_panel_label",
      "fg": "var(cursor_text)"
    },
    {
      "class": "quick_panel_path_label",
      "fg": "var(cursor_text_dim)"
    },
    {
      "class": "sidebar_heading",
      "fg": "var(cursor_text)"
    },
    {
      "class": "sidebar_label",
      "fg": "var(cursor_text_dim)"
    },
    {
      "class": "sidebar_label",
      "parents": [
        {
          "class": "tree_row",
          "attributes": [
            "hover"
          ]
        }
      ],
      "fg": "var(cursor_text)"
    },
    {
      "class": "sidebar_label",
      "parents": [
        {
          "class": "tree_row",
          "attributes": [
            "selected"
          ]
        }
      ],
      "fg": "var(cursor_text)"
    },
    {
      "class": "icon_folder",
      "content_margin": [
        8,
        8
      ],
      "layer0.opacity": 1,
      "layer0.tint": "var(mizu_folder)"
    },
    {
      "class": "icon_folder_loading",
      "content_margin": [
        8,
        8
      ],
      "layer0.opacity": 1,
      "layer0.tint": "var(mizu_folder)"
    },
    {
      "class": "icon_folder_dup",
      "content_margin": [
        8,
        8
      ],
      "layer0.opacity": 0.85,
      "layer0.tint": "var(mizu_folder)"
    },
    {
      "class": "vcs_status_badge",
      "content_margin": [
        7,
        7
      ],
      "tint_modifier": [
        168,
        204,
        124,
        1
      ]
    },
    {
      "class": "disclosure_button_control",
      "content_margin": [
        8,
        8
      ],
      "layer0.tint": "var(cursor_icon)",
      "layer0.opacity": 1
    },
    {
      "class": "sidebar_button_control",
      "content_margin": [
        10,
        10
      ],
      "layer0.tint": "var(cursor_icon)",
      "layer0.opacity": 1
    },
    {
      "class": "panel_button_control",
      "content_margin": [
        10,
        10
      ],
      "layer0.tint": "var(cursor_icon)",
      "layer0.opacity": 1
    },
    {
      "class": "status_button",
      "fg": "var(cursor_status_text)",
      "layer0.tint": "var(cursor_status_button)",
      "layer0.opacity": 0
    },
    {
      "class": "status_button",
      "attributes": [
        "hover"
      ],
      "fg": "var(cursor_status_text)",
      "layer0.tint": "var(cursor_status_button_hover)",
      "layer0.opacity": 1
    }
  ]
}
